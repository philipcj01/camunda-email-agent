# ─── Camunda 8 SaaS ────────────────────────────────────────────────────────────
CAMUNDA_CLUSTER_ID=
CAMUNDA_CLUSTER_REGION=bru-2
CAMUNDA_CLIENT_ID=
CAMUNDA_CLIENT_SECRET=
CAMUNDA_OAUTH_URL=https://login.cloud.camunda.io/oauth/token
# Console API creds (for managing per-tenant cluster secrets)
CAMUNDA_CONSOLE_CLIENT_ID=
CAMUNDA_CONSOLE_CLIENT_SECRET=
CAMUNDA_CONSOLE_OAUTH_URL=https://login.cloud.camunda.io/oauth/token
CAMUNDA_CONSOLE_BASE_URL=https://api.cloud.camunda.io

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_PROFILE=default

# Filled in after `cdk deploy` from stack outputs
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=
DYNAMODB_TABLE=email-agent-main
S3_KNOWLEDGE_BUCKET=
BEDROCK_KB_ID=
SECRETS_MANAGER_PREFIX=email-agent

# ─── Application ───────────────────────────────────────────────────────────────
# HMAC secret used to authenticate webhook calls from Camunda BPMN → our API
WEBHOOK_SIGNING_SECRET=change-me-to-a-long-random-string

APP_URL=http://localhost:3000

# ─── Next.js public env (frontend) ─────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_AWS_REGION=eu-west-1

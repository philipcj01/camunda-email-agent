{
  "name": "camunda-email-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Camunda 8 SaaS Email Agent — multi-tenant platform for configuring email-driven AI agents",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",

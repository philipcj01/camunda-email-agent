    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.1",
    "prettier": "^3.4.1"
  }
}
